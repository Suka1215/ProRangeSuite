{
  "name": "prorange-test-suite",
  "private": true,
  "version": "1.0.0",
  "description": "Electron desktop wrapper for the ProRange test suite.",
  "author": "ProRange",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "npm run build && node server.js",
    "desktop:dev": "node electron/dev.mjs",
    "desktop:start": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "desktop:dist:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip",
    "desktop:dist:win": "npm run build && electron-builder --win nsis zip"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.15.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.prorange.desktop",
    "productName": "ProRange Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "gspro_bridge.py",
        "to": "gspro_bridge.py"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
